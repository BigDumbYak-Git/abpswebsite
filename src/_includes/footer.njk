<footer class="site-footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <img src="/assets/logos/White600px-2up.png" alt="{{ settings.siteName }}">
        <p>{{ settings.footerBlurb }}</p>
      </div>
      <div class="footer-col">
        <h4>Navigation</h4>
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/services/">Services</a></li>
          <li><a href="/about/">About</a></li>
          <li><a href="/contact/">Contact</a></li>
          {% if settings.facebookUrl %}
          <li>
            <a href="{{ settings.facebookUrl }}" target="_blank" rel="noopener noreferrer" class="social-link">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.312 0 2.686.236 2.686.236v2.97h-1.513c-1.491 0-1.956.93-1.956 1.883v2.271h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/>
              </svg>
              Facebook
            </a>
          </li>
          {% endif %}
        </ul>
      </div>
      <div class="footer-col">
        <h4>Contact</h4>
        <ul>
          {% if settings.phone %}
          <li><a href="tel:{{ settings.phone }}">{{ settings.phone }}</a></li>
          {% endif %}
          {% if settings.email %}
          <li><a href="mailto:{{ settings.email }}">{{ settings.email }}</a></li>
          {% endif %}
          {% if settings.city %}
          <li>{{ settings.city }}</li>
          {% endif %}
          {% if settings.officeHours %}
          <li>{{ settings.officeHours }}</li>
          {% endif %}
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; {{ copyrightYear }} {{ settings.businessName }}. {{ settings.footerText if settings.footerText else "All rights reserved." }}</p>
      <p>Built with care for our community.</p>
    </div>
  </div>
</footer>
